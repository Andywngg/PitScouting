# Runtime
NODE_ENV=development
PORT=5001
JWT_SECRET=replace_with_long_random_secret
FRONTEND_URL=http://localhost:3000

# Local Postgres (development)
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=scouting_app
DB_HOST=localhost

# Production Postgres URL (Neon/Render/etc.)
DATABASE_URL=

# Optional persistent image storage for production
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional bootstrap admin login (avoids hardcoded credentials in code)
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_NAME=Team 1334 Admin
ADMIN_TEAM_NUMBER=1334
